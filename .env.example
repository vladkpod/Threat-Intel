# Copy to .env and fill in real values before running locally.

# API key for the admin router (/admin/*).
# All admin endpoints require the x-admin-api-key header to match this value.
ADMIN_API_KEY=change-me-before-use

# Port for the API server (default: 3001)
PORT=3001

# CORS allowed origin (default: http://localhost:5173 for Vite dev server)
# Set to your production frontend URL in production.
# CORS_ORIGIN=https://your-app.example.com

# Path to the PGlite data directory (default: .pglite/data relative to repo root)
# PGLITE_DATA_DIR=

# Anthropic API key — required for LLM-backed feed workers (NCSC triage/extraction)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
