{
  "name": "threat-intel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '**/*.eval.ts' --passWithNoTests",
    "eval": "vitest run tests/eval",
    "lint": "eslint .",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.8",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "sonner": "^2.0.7"
  }
}
